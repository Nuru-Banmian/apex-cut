# LLM 提供商: deepseek / openai / anthropic
LLM_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── 视觉分析提供商 ──
# 可选: openai / zhipu / qwen
# 推荐国内用户用 zhipu（智谱AI GLM-4V-Plus），API 完全兼容 OpenAI 格式
VISION_PROVIDER=zhipu

# OpenAI（GPT-4o，视觉分析）
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# 智谱AI GLM-4V-Plus（国产推荐）
# 注册地址: https://open.bigmodel.cn
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 阿里百炼 Qwen（文本+视觉通用 Key，一个 Key 同时支持两种用途）
# 注册地址: https://dashscope.aliyun.com
# 文本模型: qwen-max / qwen-plus / qwen-turbo
# 视觉模型: qwen-vl-max
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_TEXT_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Anthropic（可选第三种提供商）
# ANTHROPIC_API_KEY=sk-ant-your-key-here
